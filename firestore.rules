rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return request.auth != null;
    }

    function isValidSubmission() {
      let data = request.resource.data;
      return data.name is string && data.name.size() > 2 && data.name.size() < 100
          && data.email.matches('.*@.*\\..*')
          && data.whatsapp.size() >= 10
          && data.favoriteGenre in ['', 'fiction', 'mystery', 'sci-fi', 'non-fiction'];
    }

    // 1. Membership Requests: Public can create, but with validation
    match /submissions/{submissionId} {
      allow create: if isValidSubmission(); 
      allow read, delete, update: if isAdmin(); 
    }

    // 2. Global Site Content: Public read, Admin write
    match /siteContent/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 3. Activity Logs: Admin only
    match /activityLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
